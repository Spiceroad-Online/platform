---
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import Seo from '../components/astro/Seo.astro';
import WebComponents from '../components/astro/WebComponents.astro';
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
  pathname: string;
  hasParticles?: boolean;
};

const { title, description, pathname, hasParticles = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} pathname={pathname} />
  </head>
  <body {...(hasParticles ? { 'data-particles': true } : {})}>
    <WebComponents />
    {hasParticles && <canvas class="bg-particles" aria-hidden="true"></canvas>}
    <Header pathname={pathname} />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/site';
    </script>
  </body>
</html>
