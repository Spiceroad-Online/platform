---
import { apiConfig } from '../lib/config';
import { getDashboardData } from '../lib/content';
import { routes } from '../lib/routes';
import PlatformLayout from '../layouts/PlatformLayout.astro';

const dashboard = getDashboardData();
---

<PlatformLayout
  title="Dashboard"
  description="Member dashboard mockup for orders, downloads, uploads, and future account flows."
  pathname={Astro.url.pathname}
>
  <section class="page-shell">
    <div class="container">
      <div class="breadcrumbs"><a href={routes.home}>Home</a> / <span>Dashboard</span></div>
      <h1 class="section-title">Client Dashboard</h1>
      <p class="section-copy">A delivery portal for paid products, free claimed resources, and upload-based orders.</p>

      <div class="dashboard-grid">
        <aside class="dashboard-panel stack-gap-sm">
          <nav class="side-menu" aria-label="Dashboard sections">
            {dashboard.sections.map((section, index) => (
              <a class:list={{ active: index === 0 }} href="#">{section}</a>
            ))}
          </nav>

          <sr-card>
            <div class="dashboard-note">
              <p class="dashboard-note-label"><sr-text tone="primary">Backend readiness</sr-text></p>
              <p>API base URL: {apiConfig.apiBaseUrl}</p>
              <p>Uploads URL: {apiConfig.uploadsBaseUrl}</p>
            </div>
          </sr-card>
        </aside>

        <section class="dashboard-panel stack-gap-sm">
          <div class="stat-grid">
            {dashboard.metrics.map((metric) => (
              <a class="stat-box link-card" href={metric.href} aria-label={`${metric.label}: ${metric.value}`}>
                <strong>{metric.value}</strong><span>{metric.label}</span>
              </a>
            ))}
          </div>

          <sr-tabs id="dashboard-downloads"></sr-tabs>

          <table id="dashboard-orders" class="table">
            <thead><tr><th>Product</th><th>Status</th><th>Updated</th><th>Action</th></tr></thead>
            <tbody>
              {dashboard.orders.map((order) => (
                <tr>
                  <td>{order.product}</td>
                  <td>{order.status}</td>
                  <td>{order.updated}</td>
                  <td>{order.action}</td>
                </tr>
              ))}
            </tbody>
          </table>

          <sr-upload-box
            id="dashboard-uploads"
            heading="Upload intake placeholder"
            note="This component now isolates the upload UX so backend file handling can be added later without rewriting the page shell."
          ></sr-upload-box>
        </section>
      </div>
    </div>
  </section>
</PlatformLayout>
