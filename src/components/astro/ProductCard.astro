---
import type { FeaturedProduct } from '../../content/platform';

type Props = {
  product: FeaturedProduct;
};

const { product } = Astro.props;
const renderArtifactIcon = product.artwork === 'artifact';
---

<article class:list={['card', 'product-card', product.slug && `product-card--${product.slug}`]}>
  <div class:list={['card-art', { 'card-art-icon': !product.imageSrc, 'card-art-icon--artifact': renderArtifactIcon }]}>
    {product.imageSrc ? (
      <img src={product.imageSrc} alt={product.imageAlt ?? product.name} />
    ) : renderArtifactIcon ? (
      <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Spell-book silhouette from Game Icons via Iconify, CC BY 3.0: https://icon-sets.iconify.design/game-icons/spell-book/ -->
        <defs>
          <path id="resource-spellbook-shape" d="M319.61 20.654c13.145 33.114 13.144 33.115-5.46 63.5c33.114-13.145 33.116-13.146 63.5 5.457c-13.145-33.114-13.146-33.113 5.457-63.498c-33.114 13.146-33.113 13.145-63.498-5.459zM113.024 38.021c-11.808 21.04-11.808 21.04-35.724 24.217c21.04 11.809 21.04 11.808 24.217 35.725c11.808-21.04 11.808-21.04 35.724-24.217c-21.04-11.808-21.04-11.808-24.217-35.725m76.55 56.184c-.952 50.588-.95 50.588-41.991 80.18c50.587.95 50.588.95 80.18 41.99c.95-50.588.95-50.588 41.99-80.18c-50.588-.95-50.588-.95-80.18-41.99zm191.177 55.885c-.046 24.127-.048 24.125-19.377 38.564c24.127.047 24.127.046 38.566 19.375c.047-24.126.046-24.125 19.375-38.564c-24.126-.047-24.125-.046-38.564-19.375m-184.086 83.88a96 96 0 0 0-3.492.134c-18.591 1.064-41.868 8.416-77.445 22.556L76.012 433.582c78.487-20.734 132.97-21.909 170.99-4.615V247.71c-18.076-8.813-31.79-13.399-46.707-13.737a91 91 0 0 0-3.629-.002zm122.686 11.42a209 209 0 0 0-8.514.098c-12.81.417-27.638 2.215-45.84 4.522v177.135c43.565-7.825 106.85-4.2 171.244 7.566l-39.78-177.197c-35.904-8.37-56.589-11.91-77.11-12.123zm2.289 16.95c18.889.204 36.852 2.768 53.707 5.02l4.437 16.523c-23.78-3.75-65.966-4.906-92.467-.98l-.636-17.805c11.959-2.154 23.625-2.88 34.959-2.758m-250.483 4.658L60.54 313.002h24.094l10.326-46.004H71.158zm345.881 0l39.742 177.031l2.239 9.973l22.591-.152l-40.855-186.852zm-78.857 57.82c16.993.026 33.67.791 49.146 2.223l3.524 17.174c-32.645-3.08-72.58-2.889-102.995 0l-.709-17.174c16.733-1.533 34.04-2.248 51.034-2.223m-281.793 6.18l-6.924 30.004h24.394l6.735-30.004H56.389zm274.418 27.244c4.656.021 9.487.085 14.716.203l2.555 17.498c-19.97-.471-47.115.56-59.728 1.05l-.7-17.985c16.803-.493 29.189-.828 43.157-.766m41.476.447c8.268.042 16.697.334 24.121.069l2.58 17.74c-8.653-.312-24.87-.83-32.064-.502l-2.807-17.234a257 257 0 0 1 8.17-.073m-326.97 20.309l-17.985 77.928l25.035-.17l17.455-77.758H45.313zm303.164 11.848c19.608-.01 38.66.774 56.449 2.572l2.996 20.787c-34.305-4.244-85.755-7.697-119.1-3.244l-.14-17.922c20.02-1.379 40.186-2.183 59.795-2.193m-166.606 44.05c-30.112.09-67.916 6.25-115.408 19.76l-7.22 2.053l187.759-1.27v-6.347c-16.236-9.206-37.42-14.278-65.13-14.196zm134.41 6.174c-19.63.067-37.112 1.439-51.283 4.182v10.064l177.594-1.203c-44.322-8.634-89.137-13.17-126.31-13.043zM26 475v18h460v-18z" />
          <clipPath id="resource-spellbook-clip">
            <use href="#resource-spellbook-shape" />
          </clipPath>
          <filter id="resource-spellbook-shadow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="18" stdDeviation="12" flood-color="#000000" flood-opacity="0.62" />
            <feDropShadow dx="0" dy="0" stdDeviation="10" flood-color="#d98b33" flood-opacity="0.22" />
          </filter>
          <radialGradient id="resource-spellbook-backlight" cx="50%" cy="58%" r="55%">
            <stop offset="0" stop-color="#ffcb7b" stop-opacity="0.48" />
            <stop offset="0.52" stop-color="#d98b33" stop-opacity="0.16" />
            <stop offset="1" stop-color="#d98b33" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="resource-spellbook-base" x1="88" y1="24" x2="444" y2="490" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#fff2c5" />
            <stop offset="0.2" stop-color="#e3a64f" />
            <stop offset="0.42" stop-color="#7b3f17" />
            <stop offset="0.72" stop-color="#2a1106" />
            <stop offset="1" stop-color="#080302" />
          </linearGradient>
          <radialGradient id="resource-spellbook-pages" cx="45%" cy="68%" r="58%">
            <stop offset="0" stop-color="#fff3c7" />
            <stop offset="0.3" stop-color="#e7b66a" />
            <stop offset="0.62" stop-color="#8e4e1d" />
            <stop offset="1" stop-color="#1d0b04" />
          </radialGradient>
          <linearGradient id="resource-spellbook-cover" x1="155" y1="210" x2="356" y2="434" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#643014" />
            <stop offset="0.42" stop-color="#261006" />
            <stop offset="1" stop-color="#0b0402" />
          </linearGradient>
          <linearGradient id="resource-spellbook-gold" x1="0" y1="210" x2="0" y2="493" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#fff4c8" />
            <stop offset="0.32" stop-color="#e0a14b" />
            <stop offset="0.7" stop-color="#8a4a1b" />
            <stop offset="1" stop-color="#351405" />
          </linearGradient>
          <radialGradient id="resource-spellbook-spark" cx="50%" cy="50%" r="50%">
            <stop offset="0" stop-color="#fff5cb" />
            <stop offset="0.56" stop-color="#e7a64c" />
            <stop offset="1" stop-color="#7a3612" />
          </radialGradient>
        </defs>
        <circle cx="256" cy="288" r="184" fill="url(#resource-spellbook-backlight)" />
        <ellipse cx="256" cy="472" rx="178" ry="18" fill="#000000" opacity="0.48" />
        <use href="#resource-spellbook-shape" fill="#030201" opacity="0.38" transform="translate(0 10)" />
        <g filter="url(#resource-spellbook-shadow)">
          <g clip-path="url(#resource-spellbook-clip)">
            <rect width="512" height="512" fill="url(#resource-spellbook-base)" />
            <rect y="214" width="512" height="298" fill="url(#resource-spellbook-pages)" opacity="0.9" />
            <ellipse cx="256" cy="322" rx="170" ry="90" fill="url(#resource-spellbook-cover)" opacity="0.58" />
            <ellipse cx="256" cy="120" rx="210" ry="118" fill="url(#resource-spellbook-spark)" opacity="0.55" />
            <path d="M249 247 V434" stroke="#150704" stroke-width="17" opacity="0.5" />
            <path d="M264 250 V431" stroke="#f4ce84" stroke-width="5" opacity="0.42" />
            <path d="M90 438 C142 420 202 408 247 426" fill="none" stroke="#fff0ba" stroke-width="8" stroke-opacity="0.18" stroke-linecap="round" />
            <path d="M266 423 C316 412 386 417 444 433" fill="none" stroke="#fff0ba" stroke-width="8" stroke-opacity="0.14" stroke-linecap="round" />
            <path d="M292 281 C324 276 361 277 394 284" fill="none" stroke="#fff0ba" stroke-width="5" stroke-opacity="0.28" stroke-linecap="round" />
            <path d="M288 341 C322 337 362 337 400 342" fill="none" stroke="#fff0ba" stroke-width="5" stroke-opacity="0.2" stroke-linecap="round" />
            <path d="M66 314 H91 M49 362 H75 M34 456 H61" stroke="#2a1005" stroke-width="8" stroke-opacity="0.28" stroke-linecap="round" />
            <path d="M417 272 L452 428 M381 267 L385 284 M397 328 L403 345" stroke="#fff0ba" stroke-width="5" stroke-opacity="0.2" stroke-linecap="round" />
          </g>
          <use href="#resource-spellbook-shape" fill="none" stroke="#fff1bf" stroke-opacity="0.24" stroke-width="9" stroke-linejoin="round" />
          <use href="#resource-spellbook-shape" fill="none" stroke="#120603" stroke-opacity="0.52" stroke-width="3" stroke-linejoin="round" />
        </g>
        <g fill="#fff1bf" opacity="0.72">
          <circle cx="62" cy="196" r="2" />
          <circle cx="442" cy="214" r="1.8" />
          <circle cx="112" cy="168" r="1.4" />
          <circle cx="426" cy="108" r="1.2" />
        </g>
      </svg>
    ) : (
      <div class="product-monogram" aria-hidden="true">{product.monogram}</div>
    )}
  </div>
  <div class="product-body">
    <h3>{product.name}</h3>
    <p>{product.description}</p>
    <div class="price-row">
      <div class="price">
        {product.pricePrefix && <span class="price-prefix">{product.pricePrefix}</span>}
        <span class="price-value">{product.priceLabel}</span>
      </div>
      <span class="badge">{product.badge}</span>
    </div>
    <a class="btn" href={product.href}>{product.ctaLabel ?? 'Explore'}</a>
  </div>
</article>
