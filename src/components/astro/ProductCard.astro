---
import type { FeaturedProduct } from '../../content/platform';

type Props = {
  product: FeaturedProduct;
};

const { product } = Astro.props;
---

<article class="card product-card">
  <div class:list={['card-art', { 'card-art-icon': !product.imageSrc }]}>
    {product.imageSrc ? (
      <img src={product.imageSrc} alt={product.imageAlt ?? product.name} />
    ) : (
      <div class="product-monogram" aria-hidden="true">{product.monogram}</div>
    )}
  </div>
  <div class="product-body">
    <h3>{product.name}</h3>
    <p>{product.description}</p>
    <div class="price-row">
      <div class="price"><span class="price-value">{product.priceLabel}</span></div>
      <span class="badge">{product.badge}</span>
    </div>
    <a class="btn" href={product.href}>{product.ctaLabel ?? 'Explore'}</a>
  </div>
</article>
