---
import type { ProductDetail } from '../../content/platform';
import { routes } from '../../lib/routes';

type Props = {
  product: ProductDetail;
};

const { product } = Astro.props;
const isInstaller = product.slug === 'installer';
const orderPanelId = isInstaller ? 'installer-order-panel' : undefined;
---

<section class="product-layout">
  <article class:list={['hero-panel', 'product-media-card', product.slug && `product-media-card--${product.slug}`]}>
    <div class="hero-panel-media">
      <div class="media-carousel hero-media-carousel" data-carousel data-autoplay="4800">
        <div class="media-carousel-track" data-carousel-track>
          {product.gallery.map((item) => (
            <figure class="media-slide">
              <img src={item.src} alt={item.alt} />
            </figure>
          ))}
        </div>
        <div class="media-carousel-controls">
          <div class="media-carousel-dots" data-carousel-dots></div>
          <div class="media-carousel-nav">
            <button class="media-carousel-button" type="button" data-carousel-prev aria-label={`Previous ${product.name} screenshot`}>
              Prev
            </button>
            <button class="media-carousel-button" type="button" data-carousel-next aria-label={`Next ${product.name} screenshot`}>
              Next
            </button>
          </div>
        </div>
      </div>
    </div>
  </article>

  <aside id={orderPanelId} class:list={['side-panel', isInstaller && 'order-panel']} {...(isInstaller ? { 'data-order-panel': '' } : {})}>
    <div class="order-summary" data-order-summary>
      <div class="side-price"><span class="price-value">{product.priceLabel}</span></div>
      <p class="side-note">{product.sideNote}</p>
      <ul class="side-list">
        {product.sideList.map((item) => <li>{item}</li>)}
      </ul>
      <div class="stack-gap-sm">
        {isInstaller ? (
          <button class="btn btn-primary" type="button" data-order-open={orderPanelId}>{product.primaryActionLabel}</button>
        ) : (
          <a class="btn btn-primary" href={routes.dashboard}>{product.primaryActionLabel}</a>
        )}
        <a class="btn btn-ghost" href={routes.dashboard}>{product.secondaryActionLabel}</a>
      </div>
    </div>

    {isInstaller && (
      <form class="order-form" data-order-form hidden>
        <div class="order-form-head">
          <div>
            <span class="order-form-kicker">Installer order</span>
            <strong data-order-price>$100</strong>
          </div>
          <button class="order-close" type="button" data-order-close>Close</button>
        </div>

        <fieldset class="order-mode-switch">
          <legend>Delivery mode</legend>
          <label>
            <input type="radio" name="installer-order-mode" value="download" checked data-order-mode-option />
            <span><strong>Download</strong><small>$100</small></span>
          </label>
          <label>
            <input type="radio" name="installer-order-mode" value="bundle" data-order-mode-option />
            <span><strong>Bundle</strong><small>$150</small></span>
          </label>
        </fieldset>

        <div class="order-mode-panel" data-order-download>
          <label class="order-field" for="installer-download-url">
            <span>Client archive host URL</span>
            <input id="installer-download-url" name="downloadUrl" type="url" placeholder="https://example.com/client.zip" required data-download-required />
          </label>
          <details class="order-info">
            <summary aria-label="Download hosting instructions">i</summary>
            <p>Future guide: host the archive over HTTPS with a direct file URL, stable bandwidth, and no login wall so the installer can retrieve it during setup.</p>
          </details>
        </div>

        <div class="order-mode-panel" data-order-bundle hidden>
          <label class="order-upload-field order-upload-field-large" for="installer-client-archive">
            <span>Client archive .zip / .7z</span>
            <small>Required for bundle mode</small>
            <input id="installer-client-archive" name="clientArchive" type="file" accept=".zip,.7z,application/zip,application/x-7z-compressed" data-bundle-required />
          </label>
        </div>

        <div class="order-upload-grid">
          <label class="order-upload-field" for="installer-tou-file">
            <span>Terms of Use .txt</span>
            <small>Required</small>
            <input id="installer-tou-file" name="termsFile" type="file" accept=".txt,text/plain" required />
          </label>
          <label class="order-upload-field" for="installer-license-file">
            <span>License .txt</span>
            <small>Required</small>
            <input id="installer-license-file" name="licenseFile" type="file" accept=".txt,text/plain" required />
          </label>
        </div>

        <label class="order-upload-field" for="installer-logo-file">
          <span>Logo</span>
          <small>Required</small>
          <input id="installer-logo-file" name="logoFile" type="file" accept="image/png,image/jpeg,image/webp,.png,.jpg,.jpeg,.webp" required />
        </label>

        <label class="order-upload-field" for="installer-background-files">
          <span>Background images</span>
          <small>Optional, multiple files</small>
          <input id="installer-background-files" name="backgroundFiles" type="file" accept="image/png,image/jpeg,image/webp,.png,.jpg,.jpeg,.webp" multiple />
        </label>

        <button class="btn btn-primary" type="submit">Continue order</button>
        <p class="order-status" data-order-status aria-live="polite"></p>
      </form>
    )}
  </aside>

  <article class="detail-card product-overview-card">
    <div class="product-head">
      {product.heroBadges.map((badge) => <span class="badge">{badge}</span>)}
    </div>
    <h1>{product.name}</h1>
    <p class="product-subtitle">{product.subtitle}</p>
    <div class="stats">
      {product.stats.map((stat) => (
        <div class="stat-chip"><strong>{stat.value}</strong><span>{stat.label}</span></div>
      ))}
    </div>
    <div class="hero-actions">
      {isInstaller ? (
        <button class="btn btn-primary" type="button" data-order-open={orderPanelId}>{product.primaryActionLabel}</button>
      ) : (
        <a class="btn btn-primary" href={routes.dashboard}>{product.primaryActionLabel}</a>
      )}
      <a class="btn btn-ghost" href={routes.products}>Back to Catalog</a>
    </div>
  </article>

  <section class="product-section">
    <div class="split-two">
      <article class="detail-card">
        <h2>What&apos;s included</h2>
        <ul>
          {product.included.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="detail-card">
        <h2>Good fit for</h2>
        <ul>
          {product.goodFit.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="product-section">
    <article class="detail-card">
      <h2>{product.comparisonTitle}</h2>
      <table class="table">
        <thead>
          <tr>
            <th>{product.comparisonHeaders[0]}</th>
            <th>{product.comparisonHeaders[1]}</th>
            <th>{product.comparisonHeaders[2]}</th>
          </tr>
        </thead>
        <tbody>
          {product.comparisonRows.map((row) => (
            <tr>
              <td>{row.tier}</td>
              <td>{row.price}</td>
              <td>{row.includes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="product-section">
    <div class="grid-3">
      {product.faqs.map((faq) => (
        <article class="faq-item"><h3>{faq.question}</h3><p>{faq.answer}</p></article>
      ))}
    </div>
  </section>
</section>
